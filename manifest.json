{
  "manifest_version": 3,
  "name": "SenseiScan",
  "version": "1.0.0",
  "description": "Replace Sensei's Library Go diagrams with interactive WGo.js boards",
  "host_permissions": [
    "https://senseis.xmp.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://senseis.xmp.net/*"],
      "js": ["lib/wgo.js", "content.js"],
      "css": ["lib/wgo.css", "content.css"],
      "run_at": "document_idle"
    }
  ]
}
